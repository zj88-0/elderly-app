rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: Owner can update their own profile; anyone authenticated can read
    match /users/{userId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Groups: Allow update if the requester is the owner, admin, or adding themselves to the group
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null; // Simplest fix for joining
      allow delete: if request.auth != null && (resource == null || resource.data.elderlyId == request.auth.uid);
    }
    
    // Invite Codes: lookup mapping for joining groups
    match /invite_codes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Fixed: 'resource == null' allows deleting codes that might be missing or never existed properly
      allow update, delete: if request.auth != null && (resource == null || resource.data.elderlyId == request.auth.uid);
    }

    // Messages: Shared among group members
    match /messages/{groupId}/msgs/{msgId} {
      allow read, write: if request.auth != null;
    }
    match /messages/{groupId}/unread/{userId} {
      allow read, write: if request.auth != null;
    }

    // SOS: Critical alerts
    match /sos/{sosId} {
      allow read, create, update: if request.auth != null;
    }

    // Check-in summary: Caregivers (admins) also need write access to change intervals
    match /checkin_summary/{elderlyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; 
    }

    // Check-in event history: The elderly writes their history here
    match /checkins/{elderlyId}/events/{eventId} {
      allow read, write: if request.auth != null;
    }

    // Wellbeing entries
    match /wellbeing/{elderlyId}/entries/{entryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == elderlyId;
    }
  }
}
